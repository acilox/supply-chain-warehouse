APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# SAP HANA
SAP_HOST=sap.example.com
SAP_PORT=30015
SAP_USER=supply_chain_dw_reader
SAP_PASSWORD=__PLACEHOLDER__

# Oracle WMS
ORACLE_HOST=wms.example.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=WMSPROD
ORACLE_USER=supply_chain_dw_reader
ORACLE_PASSWORD=__PLACEHOLDER__

# Snowflake DW
SNOWFLAKE_ACCOUNT=abc12345.us-east-1
SNOWFLAKE_USER=supply_chain_dw_etl
SNOWFLAKE_PASSWORD=__PLACEHOLDER__
SNOWFLAKE_WAREHOUSE=SUPPLY_CHAIN_WH
SNOWFLAKE_DATABASE=SUPPLY_CHAIN_DW
SNOWFLAKE_SCHEMA=PUBLIC

# AWS S3
AWS_ACCESS_KEY_ID=__PLACEHOLDER__
AWS_SECRET_ACCESS_KEY=__PLACEHOLDER__
AWS_REGION=us-east-1
S3_BUCKET=supply_chain_dw-lake
S3_RAW_PREFIX=raw/
S3_CURATED_PREFIX=curated/

# PostgreSQL (Grafana metrics)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supply_chain_dw_metrics
POSTGRES_USER=supply_chain_dw
POSTGRES_PASSWORD=__PLACEHOLDER__

# MQTT (IoT)
MQTT_HOST=mqtt.example.com
MQTT_PORT=1883
MQTT_USER=supply_chain_dw
MQTT_PASSWORD=__PLACEHOLDER__
MQTT_TOPIC_TELEMETRY=supply_chain_dw/telemetry/+

# APIs
OPENWEATHER_API_KEY=__PLACEHOLDER__
FEDEX_API_KEY=__PLACEHOLDER__
UPS_API_KEY=__PLACEHOLDER__

# Pipeline
PIPELINE_BATCH_SIZE=5000
SOURCES_CONFIG_PATH=config/sources.yaml

# IoT thresholds
TELEMETRY_TEMP_MIN_C=2.0
TELEMETRY_TEMP_MAX_C=8.0
TELEMETRY_ANOMALY_ZSCORE=2.5
